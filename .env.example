# Network
TRIAGE_HOST=127.0.0.1
TRIAGE_PORT=8000
TRIAGE_CORS_ORIGINS=localhost

# Storage
TRIAGE_DATA_DIR=./data
TRIAGE_CASES_DIR=./cases

# Investigation limits
TRIAGE_MAX_UPLOAD_MB=500
TRIAGE_INVESTIGATION_TIMEOUT_SECONDS=1800
TRIAGE_DETECTOR_TIMEOUT_SECONDS=30
TRIAGE_QUEUE_SYNC_INTERVAL_SECONDS=30

# Session policy
TRIAGE_SESSION_TTL_HOURS=12
TRIAGE_SESSION_IDLE_HOURS=2
TRIAGE_SECURE_COOKIES=0

# Optional runtime markers
TRIAGE_RUNTIME_MODE=local

# Optional demo redaction for public screenshots and demos
# TRIAGE_DEMO_REDACTION=1
# TRIAGE_DEMO_REDACTION_VALUES=demo-host,demo-user

# Optional hardening
# TRIAGE_CSRF_SECRET=replace-with-long-random-string
